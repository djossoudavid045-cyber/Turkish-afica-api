<script>
// ============ CONFIGURATION ============
const CONFIG = {
  feePercent: 2.5,
  minFeeUSD: 0.50,
  apiBase: 'https://open.er-api.com/v6/latest',
  africanCurrencies: ['XOF','XAF','NGN','KES','GHS','MAD','ZAR','EGP','TND','DZD','MUR','RWF','UGX','ZMW','BWP','NAD','LSL','SZL','MWK','MZN','AOA','CDF','GNF','LRD','SDG','SOS','SSP','STN','TZS','ERN','ETB','DJF','KMF','CVE','GMD','MRU','SCR','SLL','MGA','BIF'],
  majorCurrencies: ['TRY','EUR','USD','GBP','CHF','JPY','CAD','AUD','CNY'],
  currencyNames: {
    TRY:'Livre Turque',EUR:'Euro',USD:'Dollar US',GBP:'Livre Sterling',
    XOF:'Franc CFA (UEMOA)',XAF:'Franc CFA (CEMAC)',NGN:'Naira Nigérian',
    KES:'Shilling Kenyan',GHS:'Cedi Ghannéen',MAD:'Dirham Marocain',
    ZAR:'Rand Sud-Africain',EGP:'Livre Égyptienne',TND:'Dinar Tunisien',
    DZD:'Dinar Algérien'
  },
  currencyFlags: {
    TRY:'🇹🇷',EUR:'🇪🇺',USD:'🇺🇸',GBP:'🇬🇧',XOF:'🌍',XAF:'🌍',NGN:'🇳🇬',
    KES:'🇰🇪',GHS:'🇬🇭',MAD:'🇲🇦',ZAR:'🇿🇦',EGP:'🇪🇬',TND:'🇹🇳',DZD:'🇩🇿'
  }
};

// ============ STATE ============
let state = {
  rates: null,
  user: null,
  token: null,
  transfers: []
};

// ============ INIT ============
document.addEventListener('DOMContentLoaded', async function() {
  populateCurrencySelects();
  setupDirectionTabs();
  await fetchRates();
  heroSimulate();
  
  // Auto-connexion si token stocké
  const saved = localStorage.getItem('multitransfer_session');
  if (saved) {
    try {
      state = JSON.parse(saved);
      if (state.user) {
        updateAuthUI();
        document.getElementById('dashboard').style.display = 'block';
        updateDashboard();
      }
    } catch(e) {}
  }
});

// ============ CURRENCY SELECTS ============
function populateCurrencySelects() {
  const allCurrencies = [...CONFIG.majorCurrencies, ...CONFIG.africanCurrencies];
  const selects = ['calcFrom','calcTo','sendFrom','sendTo'];
  
  selects.forEach(id => {
    const sel = document.getElementById(id);
    if (!sel) return;
    sel.innerHTML = allCurrencies.map(c => {
      const flag = CONFIG.currencyFlags[c] || '💱';
      const name = CONFIG.currencyNames[c] || c;
      return `<option value="${c}">${flag} ${c} — ${name}</option>`;
    }).join('');
  });
  
  // Défauts
  document.getElementById('calcFrom').value = 'TRY';
  document.getElementById('calcTo').value = 'XOF';
}

function setupDirectionTabs() {
  document.querySelectorAll('.direction-tab').forEach(tab => {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.direction-tab').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      document.getElementById('calcFrom').value = this.dataset.from;
      document.getElementById('calcTo').value = this.dataset.to;
      calculateFull();
    });
  });
}

// ============ RATES ============
async function fetchRates() {
  try {
    const resp = await fetch(`${CONFIG.apiBase}/TRY`);
    const data = await resp.json();
    if (data.result === 'success') {
      state.rates = data.rates;
      renderRates();
      return data.rates;
    }
  } catch(e) {
    console.warn('API indisponible, utilisation de taux simulés');
  }
  
  // Fallback
  state.rates = {
    TRY:1, USD:0.031, EUR:0.028, GBP:0.024,
    XOF:18.5, XAF:18.5, NGN:52, KES:4, GHS:0.38,
    MAD:0.31, ZAR:0.52, EGP:0.96, TND:0.095, DZD:4.1
  };
  renderRates();
  return state.rates;
}

function renderRates() {
  const grid = document.getElementById('ratesGrid');
  const currencies = Object.keys(state.rates).filter(c => 
    CONFIG.africanCurrencies.includes(c) || 
    ['EUR','USD','GBP'].includes(c)
  ).slice(0, 18);
  
  grid.innerHTML = currencies.map(c => {
    const rate = state.rates[c];
    if (!rate) return '';
    const flag = CONFIG.currencyFlags[c] || '💱';
    const name = CONFIG.currencyNames[c] || c;
    const formatted = rate >= 1 ? rate.toFixed(4) : rate.toFixed(6);
    return `<div class="rate-card">
      <div class="drapeau">${flag}</div>
      <div class="code">${c}</div>
      <div class="rate-value">${formatted}</div>
      <div class="rate-name">${name}</div>
    </div>`;
  }).join('');
}

function getRate(from, to) {
  if (!state.rates) return 0;
  const rFrom = state.rates[from] || 1;
  const rTo = state.rates[to] || 1;
  return rFrom > 0 ? rTo / rFrom : 0;
}

function calculateTransfer(amount, from, to) {
  const rate = getRate(from, to);
  const rateToUSD = getRate(from, 'USD');
  const amountUSD = amount * (rateToUSD || 0);
  let feeUSD = amountUSD * (CONFIG.feePercent / 100);
  if (feeUSD < CONFIG.minFeeUSD) feeUSD = CONFIG.minFeeUSD;
  const feeSource = from === 'USD' ? feeUSD : feeUSD / (getRate('USD', from) || 1);
  const netAmount = amount - feeSource;
  const received = netAmount * rate;
  
  return {
    rate, feePercent: CONFIG.feePercent,
    feeSource: Math.round(feeSource * 100) / 100,
    feeUSD: Math.round(feeUSD * 100) / 100,
    netAmount: Math.round(netAmount * 100) / 100,
    received: Math.round(received * 100) / 100
  };
}

// ============ SIMULATEUR HERO ============
function heroSimulate() {
  const amount = parseFloat(document.getElementById('heroAmount').value) || 0;
  const from = document.getElementById('heroFrom').value;
  const to = document.getElementById('heroTo').value;
  
  if (amount <= 0 || !state.rates) {
    document.getElementById('heroResult').value = '';
    document.getElementById('heroSimInfo').textContent = 'Entrez un montant valide';
    return;
  }
  
  const calc = calculateTransfer(amount, from, to);
  document.getElementById('heroResult').value = `${calc.received.toLocaleString('fr-FR')} ${to}`;
  
  const flagFrom = CONFIG.currencyFlags[from] || '💱';
  const flagTo = CONFIG.
